            if Character then
                RootPart = Character:FindFirstChild("HumanoidRootPart")
                Humanoid = Character:FindFirstChildOfClass("Humanoid")
            end
        end
    end
end)

-- AutoFarm Loop
spawn(function()
    while true do
        if AutoFarm.Enabled and RootPart then
            local desertPart = nil
            for _, v in ipairs(Workspace:GetDescendants()) do
                if (v:IsA("Part") or v:IsA("MeshPart")) and v.Name:lower():find("desert") then
                    desertPart = v
                    break
                end
            end
            if desertPart then
                local dist = (RootPart.Position - desertPart.Position).Magnitude
                if dist > 50 then
                    TeleportTo(desertPart.Position + Vector3.new(0, 5, 0))
                end
            end
            
            local curses = FindNPCs("Curse")
            local killDelay = 1 / AutoFarm.CurseKillSpeed
            for _, curse in ipairs(curses) do
                if not AutoFarm.Enabled then break end
                local hrp = curse:FindFirstChild("HumanoidRootPart")
                local hum = curse:FindFirstChildOfClass("Humanoid")
                if hrp and hum and hum.Health > 0 then
                    RootPart.CFrame = hrp.CFrame * CFrame.new(0, 0, 3)
                    for _, tool in ipairs(Character:GetChildren()) do
                        if tool:IsA("Tool") then
                            tool.Parent = Character
                            tool:Activate()
                            wait(0.1)
                        end
                    end
                    wait(killDelay)
                end
            end
            
            if AutoFarm.AutoChests then
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj:IsA("ProximityPrompt") and obj.Parent and obj.Parent.Name:lower():find("chest") then
                        local dist = (RootPart.Position - obj.Parent.Position).Magnitude
                        if dist < 15 then
                            fireproximityprompt(obj)
                            wait(0.2)
                        end
                    end
                end
            end
        end
        wait(0.3)
    end
end)

-- TeleKill Loop (включая TelePlayer)
spawn(function()
    while true do
        if RootPart then
            -- TeleBoss
            if TeleKill.TeleBoss then
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") and obj.Name:lower():find("boss") then
                        local hrp = obj:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            hrp.CFrame = RootPart.CFrame * CFrame.new(math.random(-8, 8), 0, math.random(-8, -3))
                        end
                    end
                end
            end
            
            -- TeleNPC
            if TeleKill.TeleNPC then
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") and not obj.Name:lower():find("boss") and not Players:GetPlayerFromCharacter(obj) then
                        local hrp = obj:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            hrp.CFrame = RootPart.CFrame * CFrame.new(math.random(-12, 12), 0, math.random(-12, -3))
                        end
                    end
                end
            end
            
            -- TelePlayer (телепортирует всех игроков к вам, но для них они остаются на своих позициях)
            if TeleKill.TelePlayer then
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and player.Character then
                        local char = player.Character
                        local hrp = char:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            -- Сохраняем оригинальную позицию для репликации на клиенте игрока
                            hrp.CFrame = RootPart.CFrame * CFrame.new(math.random(-10, 10), 0, math.random(-10, -3))
                        end
                    end
                end
            end
        end
        wait(0.3)
    end
end)

