        while _G.SeraphiCA.AUT_Specific.GodMode do
            pcall(function()
                local char = Utils:GetCharacter()
                if char then
                    local hum = char:FindFirstChild("Humanoid")
                    if hum then
                        hum.Health = hum.MaxHealth
                        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
                        hum:SetStateEnabled(Enum.HumanoidStateType.Physics, false)
                    end
                    for _, part in ipairs(char:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end

function AUTFeatures:NoCooldown()
    task.spawn(function()
        while _G.SeraphiCA.AUT_Specific.NoCooldown do
            pcall(function()
                local char = Utils:GetCharacter()
                if char then
                    for _, child in ipairs(char:GetChildren()) do
                        if child:IsA("NumberValue") and child.Name:find("Cooldown") then
                            child.Value = 0
                        end
                        if child:IsA("BoolValue") and child.Name:find("Cooldown") then
                            child.Value = false
                        end
                    end
                end
            end)
            task.wait(0.05)
        end
    end)
end

