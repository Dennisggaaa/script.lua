end

function AnimationModule:RotateContinuous(object, speed)
    task.spawn(function()
        while object and object.Parent do
            object.Rotation = object.Rotation + (speed or 1)
            task.wait(0.03)
        end
    end)
end

function AnimationModule:ColorTransition(object, colors, duration)
    duration = duration or 2
    local idx = 1
    task.spawn(function()
        while object and object.Parent do
            TweenService:Create(object, TweenInfo.new(duration), {BackgroundColor3 = colors[idx]}):Play()
            idx = (idx % #colors) + 1
            task.wait(duration)
        end
    end)
end

