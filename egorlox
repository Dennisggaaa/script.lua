    if key == "AutoFarm" then
        task.spawn(function()
            while Settings.AutoFarm do
                task.wait(0.5)
                local cash = LocalPlayer:FindFirstChild("leaderstats")
                if cash and cash:FindFirstChild("Cash") then
                    cash.Cash.Value = cash.Cash.Value + 100
                end
            end
        end)
    elseif key == "SpeedBypass" then
        task.spawn(function()
            while Settings.SpeedBypass do
                task.wait(0.1)
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.WalkSpeed = Settings.SpeedValue or 50
                end
            end
        end)
    elseif key == "AntiAFK" then
        task.spawn(function()
            while Settings.AntiAFK do
                task.wait(60)
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame + Vector3.new(0, 0.1, 0)
                end
            end
        end)
    end
end

