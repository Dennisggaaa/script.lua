-- ===================== РАБОЧИЕ ФУНКЦИИ ФАРМА =====================
local function ExecuteFarmFunction(key)
    if key == "AutoQuest" then
        task.spawn(function()
            while FarmSettings.AutoQuest do
                task.wait(0.5)
                local args = {
                    [1] = "GetQuest"
                }
                ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("QuestEvent"):FireServer(unpack(args))
                task.wait(0.5)
                args = {
                    [1] = "CompleteQuest"
                }
                ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("QuestEvent"):FireServer(unpack(args))
                task.wait(2)
            end
        end)
    elseif key == "AutoFarmNPC" then
        task.spawn(function()
            while FarmSettings.AutoFarmNPC do
                task.wait(0.1)
                local npc = Workspace:FindFirstChild("NPCs")
                if npc then
                    for _, v in pairs(npc:GetChildren()) do
                        if v:IsA("Model") and v:FindFirstChild("Humanoid") then
                            local args = {
                                [1] = "Attack",
                                [2] = v
                            }
                            ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("CombatEvent"):FireServer(unpack(args))
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
    elseif key == "AutoFruit" then
        task.spawn(function()
            while FarmSettings.AutoFruit do
                task.wait(1)
                for _, fruit in pairs(Workspace:GetChildren()) do
                    if fruit:IsA("Tool") and fruit.Name:find("Fruit") then
                        local args = {
                            [1] = "Collect",
                            [2] = fruit
                        }
                        ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("FruitEvent"):FireServer(unpack(args))
                        task.wait(0.3)
                    end
                end
                task.wait(5)
            end
        end)
    elseif key == "AutoSideQuest" then
        task.spawn(function()
            while FarmSettings.AutoSideQuest do
                task.wait(0.5)
                local args = {
                    [1] = "GetSideQuest"
                }
                ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("SideQuestEvent"):FireServer(unpack(args))
                task.wait(0.5)
                args = {
                    [1] = "CompleteSideQuest"
                }
                ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("SideQuestEvent"):FireServer(unpack(args))
                task.wait(3)
            end
        end)
    elseif key == "AutoV2Quest" then
        task.spawn(function()
            while FarmSettings.AutoV2Quest do
                task.wait(0.5)
                local args = {
                    [1] = "GetV2Quest"
                }
                ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("V2QuestEvent"):FireServer(unpack(args))
                task.wait(0.5)
                args = {
                    [1] = "CompleteV2Quest"
                }
                ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("V2QuestEvent"):FireServer(unpack(args))
                task.wait(5)
            end
        end)
    elseif key == "AutoBoss" then
        task.spawn(function()
            while FarmSettings.AutoBoss do
                task.wait(0.5)
                for _, boss in pairs(Workspace:GetChildren()) do
                    if boss:IsA("Model") and boss.Name:find("Boss") and boss:FindFirstChild("Humanoid") then
                        local args = {
                            [1] = "AttackBoss",
                            [2] = boss
                        }
                        ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("BossEvent"):FireServer(unpack(args))
                        task.wait(0.5)
                    end
                end
                task.wait(3)
            end
        end)
    elseif key == "AutoCollect" then
        task.spawn(function()
            while FarmSettings.AutoCollect do
                task.wait(0.1)
                for _, item in pairs(Workspace:GetChildren()) do
                    if item:IsA("Part") and item.Name:find("Item") then
                        local args = {
                            [1] = "Collect",
                            [2] = item
                        }
                        ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("CollectEvent"):FireServer(unpack(args))
                    end
                end
                task.wait(0.5)
            end
        end)
    elseif key == "AutoTeleport" then
        task.spawn(function()
            while FarmSettings.AutoTeleport do
                task.wait(0.5)
                local islands = {"StarterIsland", "ClownIsland", "SharkPark", "SkyIsland", "FishmanIsland"}
                for _, island in pairs(islands) do
                    local pos = Workspace:FindFirstChild(island)
                    if pos then
                        LocalPlayer.Character.HumanoidRootPart.CFrame = pos.CFrame + Vector3.new(0, 10, 0)
                        task.wait(2)
                    end
                end
                task.wait(10)
            end
        end)
    elseif key == "AutoHaki" then
        task.spawn(function()
            while FarmSettings.AutoHaki do
                task.wait(0.1)
                local args = {
                    [1] = "TrainHaki"
                }
                ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("HakiEvent"):FireServer(unpack(args))
                task.wait(0.5)
            end
