function Watermark:AnimateAll(wm)
    -- Glow pulse
    AnimationModule:GlowPulse(wm.OuterGlow, 12)
    AnimationModule:GlowPulse(wm.InnerGlow, 18)
    
    -- Star rotation
    task.spawn(function()
        while wm.StarIcon and wm.StarIcon.Parent do
            wm.StarIcon.Rotation = wm.StarIcon.Rotation + 0.5
            task.wait(0.03)
        end
    end)
    
    -- Star glow pulse
    task.spawn(function()
        while wm.StarGlow and wm.StarGlow.Parent do
            TweenService:Create(wm.StarGlow, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Size = UDim2.new(0, 42, 0, 42),
