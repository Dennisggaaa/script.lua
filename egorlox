local menuOpenTween = nil
WButton.MouseButton1Click:Connect(function()
    SeraphMenu.Visible = not SeraphMenu.Visible
    MenuFrame.Visible = SeraphMenu.Visible
    ToggleBlur(SeraphMenu.Visible)

    if SeraphMenu.Visible then
        MenuFrame.Position = UDim2.new(0.5, -Settings.MenuSize/2, 0.5, -350 + 50)
        MenuFrame.Size = UDim2.new(0, 0, 0, 0)
        MenuFrame.BackgroundTransparency = 1
        if menuOpenTween then menuOpenTween:Cancel() end
        menuOpenTween = TweenService:Create(MenuFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, Settings.MenuSize, 0, 700),
            Position = UDim2.new(0.5, -Settings.MenuSize/2, 0.5, -350),
            BackgroundTransparency = 0.1
        })
        menuOpenTween:Play()
        BubbleOut()
    else
        if menuOpenTween then menuOpenTween:Cancel() end
        menuOpenTween = TweenService:Create(MenuFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, -Settings.MenuSize/2, 0.5, -350 + 50),
            BackgroundTransparency = 1
        })
        menuOpenTween:Play()
        BubbleIn()
    end
end)

