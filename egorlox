function ExecuteFunction(key, active)
    if key == "Immortality" then
        task.spawn(function()
            while Settings.Immortality do
                task.wait(0.1)
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.Health = char.Humanoid.MaxHealth
                end
            end
        end)
    elseif key == "SpeedBypass" then
        task.spawn(function()
            while Settings.SpeedBypass do
                task.wait(0.1)
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.WalkSpeed = 50
                end
            end
        end)
    elseif key == "NoRender" then
        task.spawn(function()
            while Settings.NoRender do
                task.wait(0.1)
                for _, v in pairs(Workspace:GetChildren()) do
                    if v:IsA("BasePart") then v.Transparency = 1 end
                end
            end
        end)
    elseif key == "AutoParry" then
        task.spawn(function()
            while Settings.AutoParry do
                task.wait(0.05)
                local ball = Workspace:FindFirstChild("Ball")
                if ball and (ball.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude < 30 then
                    local args = {[1] = "Parry"}
                    ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("ParryEvent"):FireServer(unpack(args))
                end
            end
        end)
    elseif key == "AutoSpamParry" then
        task.spawn(function()
            while Settings.AutoSpamParry do
                task.wait(0.05)
                local args = {[1] = "Parry"}
                ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("ParryEvent"):FireServer(unpack(args))
            end
        end)
    elseif key == "TriggerBot" then
        task.spawn(function()
            while Settings.TriggerBot do
                task.wait(0.01)
                local args = {[1] = "Trigger"}
                ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("TriggerEvent"):FireServer(unpack(args))
            end
        end)
    elseif key == "AntiCurve" then
        task.spawn(function()
            while Settings.AntiCurve do
                task.wait(0.05)
                local ball = Workspace:FindFirstChild("Ball")
                if ball then
                    local dir = (LocalPlayer.Character.HumanoidRootPart.Position - ball.Position).Unit
                    ball.Velocity = dir * ball.Velocity.Magnitude
                end
            end
        end)
    elseif key == "HitEffect" then
        task.spawn(function()
            while Settings.HitEffect do
                task.wait(0.1)
                -- симуляция hit эффекта
            end
        end)
    elseif key == "Visualiser" then
        task.spawn(function()
            while Settings.Visualiser do
                task.wait(0.1)
                local ball = Workspace:FindFirstChild("Ball")
                if ball then
                    local trail = Instance.new("Trail")
                    trail.Parent = ball
                    trail.Lifetime = 0.5
                    trail.Color = ColorSequence.new(Color3.fromRGB(255, 215, 0))
                end
            end
        end)
    end
end

