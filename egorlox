    local function UpdateFakeItemsList(searchQuery)
        for _, child in ipairs(fakeItemsScroll:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        
        local allItems = GetAllItems()
        local totalHeight = 0
        local query = searchQuery or ""
        
        for _, itemData in ipairs(allItems) do
            if query == "" or itemData.Name:lower():find(query:lower()) then
                local itemBtn = Instance.new("TextButton")
                itemBtn.Size = UDim2.new(1, 0, 0, 35)
                itemBtn.BackgroundColor3 = C.BgDark
                itemBtn.BorderSizePixel = 0
                itemBtn.Text = "🎭 " .. itemData.Name
                itemBtn.TextColor3 = C.Gray
                itemBtn.TextSize = 11
                itemBtn.Font = Enum.Font.Gotham
                itemBtn.ZIndex = 154
                itemBtn.Parent = fakeItemsScroll
                Instance.new("UICorner", itemBtn).CornerRadius = UDim.new(0, 7)
                
                itemBtn.MouseButton1Click:Connect(function()
                    -- Добавляем фейковый предмет в трейд
                    table.insert(ScamTrade.FakeItems, itemData)
                    -- Пытаемся добавить предмет в GUI трейда
                    pcall(function()
                        local tradeGui = PlayerGui:FindFirstChild("TradeGUI") or PlayerGui:FindFirstChild("Trade")
                        if tradeGui then
                            -- Создаём копию предмета в трейде
                            local fakeItem = Instance.new("ImageLabel")
                            fakeItem.Size = UDim2.new(0, 50, 0, 50)
                            fakeItem.BackgroundColor3 = Color3.fromRGB(30, 30, 60)
                            fakeItem.BorderSizePixel = 1
                            fakeItem.BorderColor3 = C.RoyalGold
                            fakeItem.Image = "rbxassetid://1313579923"
                            fakeItem.ImageTransparency = 0.5
                            fakeItem.Name = itemData.Name
                            fakeItem.ZIndex = 200
                            
                            -- Ищем слот для предмета
                            local tradeSlots = {}
                            for _, obj in ipairs(tradeGui:GetDescendants()) do
                                if obj:IsA("Frame") and obj.Name:lower():find("slot") then
                                    table.insert(tradeSlots, obj)
                                end
                            end
                            if #tradeSlots > 0 then
                                fakeItem.Parent = tradeSlots[math.random(1, math.min(#tradeSlots, 9))]
                            else
                                fakeItem.Parent = tradeGui
                            end
                            
                            local itemName = Instance.new("TextLabel")
                            itemName.Size = UDim2.new(1, 0, 0, 14)
                            itemName.Position = UDim2.new(0, 0, 1, 2)
                            itemName.BackgroundTransparency = 1
                            itemName.Text = itemData.Name
                            itemName.TextColor3 = C.RoyalGold
                            itemName.TextSize = 8
                            itemName.Font = Enum.Font.GothamBold
                            itemName.TextXAlignment = Enum.TextXAlignment.Center
                            itemName.Parent = fakeItem
                            
                            -- Подсветка что предмет добавлен
                            pcall(function()
                                TweenService:Create(itemBtn, TweenInfo.new(0.3), {
                                    BackgroundColor3 = C.Success, TextColor3 = C.White
                                }):Play()
                            end)
                            wait(0.5)
                            pcall(function()
                                TweenService:Create(itemBtn, TweenInfo.new(0.3), {
                                    BackgroundColor3 = C.BgDark, TextColor3 = C.Gray
                                }):Play()
                            end)
                        end
                    end)
                end)
                
                totalHeight = totalHeight + 38
            end
        end
        
        fakeItemsScroll.CanvasSize = UDim2.new(0, 0, 0, math.max(totalHeight, 100))
    end

    fakeSearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        UpdateFakeItemsList(fakeSearchBox.Text)
    end)

    -- Начальная загрузка списка
    spawn(function()
        wait(0.5)
        UpdateFakeItemsList("")
    end)

    scroll4.CanvasSize = UDim2.new(0, 0, 0, 550)

    -- === ПЕРЕТАСКИВАНИЕ ===
    local dragging = false
    local dragStart = nil
    local frameStart = nil

    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            frameStart = frame.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local newX = Clamp(frameStart.X.Offset + delta.X, -frame.AbsoluteSize.X + 100, ScreenGui.AbsoluteSize.X - 100)
            local newY = Clamp(frameStart.Y.Offset + delta.Y, 0, ScreenGui.AbsoluteSize.Y - 60)
            frame.Position = UDim2.new(0, newX, 0, newY)
        end
    end)

    UserInputService.InputEnded:Connect(function() dragging = false end)

    -- Активируем первый таб
    SwitchTab(tabPanel:GetChildren()[1], page1)

    print("[SeraphiCA] Menu created")
    return frame
end

