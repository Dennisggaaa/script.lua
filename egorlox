local function AnimateBorder()
    local phase = 0
    while true do
        phase = phase + 0.02
        local transparency = 0.3 + math.sin(phase) * 0.2
        TweenService:Create(MenuBorder1, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {BackgroundTransparency = transparency}):Play()
        task.wait(0.1)
    end
end
