    valueDisplay.TextXAlignment = Enum.TextXAlignment.Right
    valueDisplay.TextYAlignment = Enum.TextYAlignment.Center
    valueDisplay.Parent = labelFrame
    
    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, 0, 0, 5)
    sliderBg.Position = UDim2.new(0, 0, 0, 32)
    sliderBg.BackgroundColor3 = Color3.fromRGB(25, 28, 60)
    sliderBg.BorderSizePixel = 0
    sliderBg.Parent = container
    local sliderBgCorner = Instance.new("UICorner")
    sliderBgCorner.CornerRadius = UDim.new(0, 3)
    sliderBgCorner.Parent = sliderBg
    
    local initialX = (Settings[settingKey] - minVal) / (maxVal - minVal)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(initialX, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    fill.BorderSizePixel = 0
    fill.Parent = sliderBg
    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0, 3)
    fillCorner.Parent = fill
    
    local handle = Instance.new("TextButton")
    handle.Size = UDim2.new(0, 20, 0, 20)
    handle.Position = UDim2.new(initialX, -10, 0.5, -10)
    handle.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    handle.BorderSizePixel = 2
    handle.BorderColor3 = Color3.fromRGB(255, 255, 255)
    handle.Text = ""
    handle.Parent = container
    local handleCorner = Instance.new("UICorner")
    handleCorner.CornerRadius = UDim.new(1, 0)
    handleCorner.Parent = handle
    
    local dragging = false
    handle.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    
    RunService.RenderStepped:Connect(function()
        if dragging then
            local mouse = LocalPlayer:GetMouse()
            local x = math.clamp((mouse.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
            local val = math.floor(minVal + x * (maxVal - minVal))
            Settings[settingKey] = val
            fill.Size = UDim2.new(x, 0, 1, 0)
            handle.Position = UDim2.new(x, -10, 0.5, -10)
            valueDisplay.Text = tostring(val)
            if settingKey == "SpeedValue" then
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("Humanoid") and Settings.SpeedBypass then
                    char.Humanoid.WalkSpeed = val
                end
            end
        end
    end)
    
    return container
end

