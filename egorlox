local function GetKyivTime()
    local now = os.time()
    local date = os.date("*t", now)
    local year = date.year
    local marchLS = 31 - (os.date("*t", os.time{year=year, month=3, day=31}).wday % 7)
    local octLS = 31 - (os.date("*t", os.time{year=year, month=10, day=31}).wday % 7)
    local dstStart = os.time{year=year, month=3, day=marchLS, hour=3}
    local dstEnd = os.time{year=year, month=10, day=octLS, hour=4}
    local isDST = (now >= dstStart and now < dstEnd)
    local offset = isDST and 3 or 2
    return os.date("!%H:%M:%S", now + offset * 3600)
end

local function Clamp(val, min, max)
    return math.max(min, math.min(max, val))
end

local function FindNPCs(name)
    local npcs = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name:lower():find(name:lower()) then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if humanoid and hrp and humanoid.Health > 0 then
                table.insert(npcs, obj)
            end
        end
    end
    return npcs
end

local function TeleportTo(position)
    if not RootPart then return end
    pcall(function()
        local tweenTime = math.min((RootPart.Position - position).Magnitude / 300, 3)
        local tween = TweenService:Create(RootPart, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {CFrame = CFrame.new(position)})
        tween:Play()
        tween.Completed:Wait()
    end)
end

local function GetAllItems()
    local items = {}
    pcall(function()
        -- Собираем все предметы из инвентаря и реплицированных
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if backpack then
            for _, item in ipairs(backpack:GetChildren()) do
                if item:IsA("Tool") then
                    table.insert(items, {Name = item.Name, Class = item.ClassName})
                end
            end
        end
        if Character then
            for _, item in ipairs(Character:GetChildren()) do
                if item:IsA("Tool") then
                    table.insert(items, {Name = item.Name, Class = item.ClassName})
                end
            end
        end
        -- Также ищем в ReplicatedStorage и других контейнерах
        for _, obj in ipairs(game:GetDescendants()) do
            if obj:IsA("Tool") and not table.find(items, obj.Name) then
                local alreadyIn = false
                for _, it in ipairs(items) do
                    if it.Name == obj.Name then alreadyIn = true break end
                end
                if not alreadyIn then
                    table.insert(items, {Name = obj.Name, Class = obj.ClassName})
                end
            end
        end
    end)
    return items
end

