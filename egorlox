    TweenService:Create(WelcomeText, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
        TextTransparency = 0,
        TextSize = 58
    }):Play()
    
    task.wait(0.3)
    
    PlayerNameLabel.TextTransparency = 1
