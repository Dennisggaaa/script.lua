local Utils = {}

function Utils:DeepCopy(orig)
    local orig_type = type(orig)
    local copy
    if orig_type == 'table' then
        copy = {}
        for orig_key, orig_value in next, orig, nil do
            copy[Utils:DeepCopy(orig_key)] = Utils:DeepCopy(orig_value)
        end
        setmetatable(copy, Utils:DeepCopy(getmetatable(orig)))
    else
        copy = orig
    end
    return copy
end

function Utils:GetKyivTime()
    local now = os.time()
    local date = os.date("*t", now)
    local year = date.year
    local marchLastSunday = 31 - (os.date("*t", os.time{year=year, month=3, day=31}).wday % 7)
    local octLastSunday = 31 - (os.date("*t", os.time{year=year, month=10, day=31}).wday % 7)
    local dstStart = os.time{year=year, month=3, day=marchLastSunday, hour=3}
    local dstEnd = os.time{year=year, month=10, day=octLastSunday, hour=4}
    local isDST = (now >= dstStart and now < dstEnd)
    local kyivOffset = isDST and 3 or 2
    local kyivTime = now + kyivOffset * 3600
    return os.date("!%H:%M:%S", kyivTime)
end

function Utils:Clamp(val, min, max)
    return math.max(min, math.min(max, val))
end

function Utils:FireRemote(remote, ...)
    if remote then
        pcall(function()
            if remote:IsA("RemoteEvent") then
                remote:FireServer(...)
            elseif remote:IsA("RemoteFunction") then
                remote:InvokeServer(...)
            end
        end)
    end
end

