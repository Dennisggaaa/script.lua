local function EncryptKey()
    local key = "081324"
    local encoded = ""
    for i = 1, #key do
        local char = string.byte(key, i)
        encoded = encoded .. string.char(char + 7)
    end
    return encoded
end

local function DecryptKey(encrypted)
    local decoded = ""
    for i = 1, #encrypted do
        local char = string.byte(encrypted, i)
        decoded = decoded .. string.char(char - 7)
    end
    return decoded
end

