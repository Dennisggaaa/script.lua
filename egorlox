local DragSystem = {}

function DragSystem:MakeDraggable(frame, handle)
    local dragging = false
    local dragStart = nil
    local frameStart = nil
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            frameStart = frame.Position
            
            -- Slightly lift frame
            TweenService:Create(frame, TweenInfo.new(0.15), {
                Size = UDim2.new(0, 910, 0, 590)
            }):Play()
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            
            local newX = frameStart.X.Offset + delta.X
            local newY = frameStart.Y.Offset + delta.Y
            
            -- Clamp to screen
            newX = Clamp(newX, -frame.AbsoluteSize.X + 100, ScreenGui.AbsoluteSize.X - 100)
            newY = Clamp(newY, 0, ScreenGui.AbsoluteSize.Y - 60)
            
            frame.Position = UDim2.new(0, newX, 0, newY)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if dragging then
            dragging = false
            
            -- Restore size
            TweenService:Create(frame, TweenInfo.new(0.2), {
                Size = UDim2.new(0, 900, 0, 580)
            }):Play()
        end
    end)
end

