local function SpoofPurchase(gp)
    LogFrame.Visible = true
    LogText.Text = ""
    ConfirmBtn.Text = "⏳ PROCESSING..."
    ConfirmBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
    ConfirmBtn.BackgroundTransparency = 0.3
    
    local logs = {}
    local function addLog(text, color)
        table.insert(logs, {text = text, color = color or Color3.fromRGB(200, 200, 220)})
        local full = ""
        for _, l in ipairs(logs) do
            full = full .. l.text .. "\n"
        end
        LogText.Text = full
        task.wait(0.3)
    end
    
    addLog("🔍 Scanning server security...", Color3.fromRGB(255, 200, 50))
    task.wait(0.5)
    
    addLog("📦 GamePass detected: " .. gp.name, Color3.fromRGB(100, 200, 255))
    task.wait(0.4)
    
    addLog("💰 Price: " .. gp.price .. " Robux", Color3.fromRGB(255, 200, 50))
    task.wait(0.4)
    
    addLog("🔄 Sending purchase request to Roblox servers...", Color3.fromRGB(200, 200, 220))
    task.wait(0.5)
    
    -- Симуляция проверки защиты
    local protectionLevel = math.random(1, 100)
    addLog("🛡️ Server protection level: " .. protectionLevel .. "%", Color3.fromRGB(150, 150, 200))
    task.wait(0.4)
    
    local success = protectionLevel < 50
    local fakeRobux = math.random(100, 5000)
    addLog("💳 Spoofed Robux balance: " .. fakeRobux .. " R$", Color3.fromRGB(255, 200, 50))
    task.wait(0.4)
    
    if success then
        addLog("✅ Purchase validated! Access granted.", Color3.fromRGB(0, 255, 120))
        task.wait(0.3)
        addLog("🎁 " .. gp.name .. " added to inventory!", Color3.fromRGB(0, 255, 200))
        task.wait(0.3)
        addLog("📦 Item unlocked successfully!", Color3.fromRGB(100, 255, 100))
        
        -- Apply the gamepass effect (simulate)
        local success2, err = pcall(function()
            local events = ReplicatedStorage:FindFirstChild("Events")
            if events then
                local purchaseEvent = events:FindFirstChild("PurchaseEvent")
                if purchaseEvent then
                    purchaseEvent:FireServer(gp.id, "spoofed")
                end
                local unlockEvent = events:FindFirstChild("UnlockEvent")
                if unlockEvent then
                    unlockEvent:FireServer(gp.id)
                end
            end
            -- Try direct remote
            local remote = ReplicatedStorage:FindFirstChild("RemoteEvent")
            if remote then
                remote:FireServer("PurchaseGamePass", gp.id)
            end
        end)
        if not success2 then
            addLog("⚠️ Could not apply item (server-side)", Color3.fromRGB(255, 200, 50))
        end
        
        ConfirmBtn.Text = "✅ ACCESS GRANTED!"
        ConfirmBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 80)
        ConfirmBtn.BackgroundTransparency = 0.1
        
        -- Play success sound
        local sound = Instance.new("Sound")
        sound.SoundId = "rbxassetid://9120263686"
        sound.Volume = 0.3
        sound.Parent = LocalPlayer.Character or LocalPlayer
        sound:Play()
        task.wait(0.5)
        sound:Destroy()
        
    else
        addLog("❌ Purchase rejected by server security!", Color3.fromRGB(255, 80, 80))
        task.wait(0.3)
        addLog("🔒 Reason: High protection level detected", Color3.fromRGB(255, 150, 80))
        task.wait(0.3)
        addLog("💡 Try again with different GamePass or lower price", Color3.fromRGB(255, 200, 50))
        
        ConfirmBtn.Text = "❌ PURCHASE FAILED"
        ConfirmBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        ConfirmBtn.BackgroundTransparency = 0.2
    end
end

