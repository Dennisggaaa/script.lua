    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = COLORS.Primary
    fill.BorderSizePixel = 0
    fill.Parent = slider
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)
    
    local handle = Instance.new("Frame")
    handle.Size = UDim2.new(0, 22, 0, 22)
    handle.Position = UDim2.new((default - min) / (max - min), -11, 0.5, -11)
    handle.BackgroundColor3 = COLORS.Primary
    handle.BorderSizePixel = 0
    handle.Parent = slider
    Instance.new("UICorner", handle).CornerRadius = UDim.new(0, 11)
    
    local handleGlow = Instance.new("Frame")
    handleGlow.Size = UDim2.new(1, 6, 1, 6)
    handleGlow.Position = UDim2.new(0, -3, 0, -3)
    handleGlow.BackgroundColor3 = COLORS.Primary
    handleGlow.BackgroundTransparency = 0.8
    handleGlow.BorderSizePixel = 0
    handleGlow.ZIndex = -1
    handleGlow.Parent = handle
    Instance.new("UICorner", handleGlow).CornerRadius = UDim.new(0, 14)
    
    local value = default
    local dragging = false
    
    local function UpdateSlider(newVal)
        value = math.clamp(newVal, min, max)
        local percent = (value - min) / (max - min)
        fill.Size = UDim2.new(percent, 0, 1, 0)
        handle.Position = UDim2.new(percent, -11, 0.5, -11)
        valLabel.Text = tostring(math.floor(value))
        if callback then pcall(callback, value) end
    end
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)
    
    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    
    slider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local pos = input.Position.X - slider.AbsolutePosition.X
            local percent = math.clamp(pos / slider.AbsoluteSize.X, 0, 1)
            UpdateSlider(min + percent * (max - min))
            dragging = true
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local pos = input.Position.X - slider.AbsolutePosition.X
            local percent = math.clamp(pos / slider.AbsoluteSize.X, 0, 1)
            UpdateSlider(min + percent * (max - min))
        end
    end)
    
    return {
        Frame = frame, Slider = slider, Fill = fill, Handle = handle, ValueLabel = valLabel,
        GetValue = function() return value end,
        SetValue = function(newVal) UpdateSlider(newVal) end
    }
end

