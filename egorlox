local ParticleSystem = {}

function ParticleSystem:CreateParticle(parent, x, y, size, color, speed, lifespan, shape)
    local particle
    if shape == "circle" then
        particle = Instance.new("Frame")
        Instance.new("UICorner", particle).CornerRadius = UDim.new(0, size / 2 or 2)
    elseif shape == "star" then
        particle = Instance.new("TextLabel")
        particle.Text = "✦"
        particle.TextColor3 = color
        particle.Font = Enum.Font.GothamBlack
        particle.TextSize = size * 3
        particle.BackgroundTransparency = 1
    else
        particle = Instance.new("Frame")
        Instance.new("UICorner", particle).CornerRadius = UDim.new(0, 2)
    end

    particle.Size = UDim2.new(0, size or 4, 0, size or 4)
    particle.Position = UDim2.new(0, x, 0, y)
    if not shape or shape ~= "star" then
        particle.BackgroundColor3 = color or C.Primary
    end
    particle.BorderSizePixel = 0
    particle.BackgroundTransparency = 0.5
    particle.ZIndex = 150
    particle.Parent = parent

    spawn(function()
        local startTime = tick()
        local life = lifespan or (3 + math.random() * 4)
        local speedX = (math.random() - 0.5) * (speed or 20)
        local speedY = (math.random() - 0.5) * (speed or 20) - 10
        local startX = x
        local startY = y
        while tick() - startTime < life and particle.Parent do
            local elapsed = tick() - startTime
            local progress = elapsed / life
            particle.Position = UDim2.new(0, startX + speedX * elapsed, 0, startY + speedY * elapsed + 50 * progress * progress)
            particle.BackgroundTransparency = 0.5 + progress * 0.5
            particle.Size = UDim2.new(0, size * (1 - progress * 0.7), 0, size * (1 - progress * 0.7))
            if shape == "star" then
                particle.TextTransparency = 0.5 + progress * 0.5
            end
            wait(0.03)
        end
        pcall(function() particle:Destroy() end)
    end)
    return particle
end

function ParticleSystem:Burst(parent, count, x, y, colors, sizeRange, speed, lifespan, shapes)
    for i = 1, count do
        local size = math.random(sizeRange[1] or 2, sizeRange[2] or 6)
        local color = colors[math.random(1, #colors)]
        local shape = shapes and shapes[math.random(1, #shapes)] or nil
        local angle = math.random() * math.pi * 2
        local dist = math.random(10, 60)
        local px = x + math.cos(angle) * dist
        local py = y + math.sin(angle) * dist
        ParticleSystem:CreateParticle(parent, px, py, size, color, speed, lifespan, shape)
    end
end

