-- ===================== АНИМАЦИЯ ОТКРЫТИЯ/ЗАКРЫТИЯ МЕНЮ =====================
local menuOpen = false
local particles = {}

local function CreateBubbleEffect(startPos, endPos)
    local count = _G.ParticleCount or 50
    for i = 1, count do
        local particle = Instance.new("Frame")
        particle.Size = UDim2.new(0, math.random(3, 8), 0, math.random(3, 8))
        particle.Position = UDim2.new(0, startPos.X + math.random(-10, 10), 0, startPos.Y + math.random(-10, 10))
        particle.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
        particle.BackgroundTransparency = 0.8
        particle.BorderSizePixel = 0
        particle.Parent = ScreenGui
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 10)
        corner.Parent = particle
        
        -- Анимация частицы
        local tween = TweenService:Create(particle, TweenInfo.new(math.random(3, 6), Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, endPos.X + math.random(-50, 50), 0, endPos.Y + math.random(-50, 50)),
            BackgroundTransparency = 1,
            Size = UDim2.new(0, math.random(10, 30), 0, math.random(10, 30))
        })
        tween:Play()
        tween.Completed:Connect(function()
            particle:Destroy()
        end)
        
        table.insert(particles, particle)
    end
end

local function ToggleMenu()
    menuOpen = not menuOpen
    local watermarkPos = WatermarkLabel.AbsolutePosition
    local watermarkSize = WatermarkLabel.AbsoluteSize
    local centerX = watermarkPos.X + watermarkSize.X / 2
    local centerY = watermarkPos.Y + watermarkSize.Y / 2
    
    if menuOpen then
        -- Открытие: пузырь из ватермарка
        MainFrame.Visible = true
        MainFrame.Position = UDim2.new(0, centerX - 20, 0, centerY - 20)
        MainFrame.Size = UDim2.new(0, 40, 0, 40)
        MainFrame.BackgroundTransparency = 0.2
        
        -- Создаем эффект частиц
        CreateBubbleEffect(Vector2.new(centerX, centerY), Vector2.new(MainFrame.AbsolutePosition.X + MenuSize/2, MainFrame.AbsolutePosition.Y + MenuSize*0.335))
        
        -- Анимация появления
        local half = MenuSize / 2
        local targetPos = UDim2.new(0.5, -half, 0.5, -MenuSize * 0.335)
        local targetSize = UDim2.new(0, MenuSize, 0, MenuSize * 0.67)
        
        TweenService:Create(MainFrame, TweenInfo.new(0.8, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = targetPos,
            Size = targetSize,
            BackgroundTransparency = 0
        }):Play()
        
        TweenService:Create(MainGlow, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
            BackgroundTransparency = 0.85,
            Size = UDim2.new(1, 60, 1, 60),
            Position = UDim2.new(0, -30, 0, -30)
        }):Play()
        
        -- Показываем содержимое после анимации
        task.wait(0.4)
        ContentContainer.Visible = true
        TabContainer.Visible = true
        TitleBar.Visible = true
    else
        -- Закрытие: сворачиваем обратно в ватермарк
        ContentContainer.Visible = false
        TabContainer.Visible = false
        TitleBar.Visible = false
        
        local currentPos = MainFrame.AbsolutePosition
        local currentSize = MainFrame.AbsoluteSize
        
        TweenService:Create(MainFrame, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(0, centerX - 20, 0, centerY - 20),
            Size = UDim2.new(0, 40, 0, 40),
            BackgroundTransparency = 0.8
        }):Play()
        
        -- Эффект втягивания
        CreateBubbleEffect(Vector2.new(currentPos.X + currentSize.X/2, currentPos.Y + currentSize.Y/2), Vector2.new(centerX, centerY))
        
        task.wait(0.6)
        MainFrame.Visible = false
    end
end

