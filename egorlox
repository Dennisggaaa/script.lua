local ESPSystem = {}
local espObjects = {}

function ESPSystem:ClearESP()
    for _, obj in pairs(espObjects) do
        pcall(function() obj:Destroy() end)
    end
    espObjects = {}
end

function ESPSystem:BoxESP(player, camera)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local root = player.Character.HumanoidRootPart
    local head = player.Character:FindFirstChild("Head")
    if not head then return end
    local rootPos, rootOn = camera:WorldToViewportPoint(root.Position)
    local headPos, headOn = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
    if rootOn and headOn then
        local height = math.abs(headPos.Y - rootPos.Y)
        local width = height * 0.6
        local box = Instance.new("Frame")
        box.Name = "ESPBox"
        box.Size = UDim2.new(0, width, 0, height)
        box.Position = UDim2.new(0, headPos.X - width/2, 0, headPos.Y)
        box.BackgroundColor3 = COLORS.Primary
        box.BackgroundTransparency = 0.65
        box.BorderSizePixel = 1
        box.BorderColor3 = COLORS.Primary
        box.Parent = ScreenGui
        table.insert(espObjects, box)
    end
end

function ESPSystem:NameESP(player, camera)
    if not player.Character or not player.Character:FindFirstChild("Head") then return end
    local head = player.Character.Head
    local pos, on = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1.2, 0))
    if on then
        local label = Instance.new("TextLabel")
        label.Name = "ESPName"
        label.Size = UDim2.new(0, 180, 0, 18)
        label.Position = UDim2.new(0, pos.X - 90, 0, pos.Y - 28)
        label.BackgroundTransparency = 1
        label.Text = player.Name
        label.TextColor3 = COLORS.Light
        label.TextSize = 12
        label.Font = Enum.Font.GothamBold
        label.TextXAlignment = Enum.TextXAlignment.Center
        label.TextStrokeTransparency = 0.5
        label.TextStrokeColor3 = COLORS.Black
        label.Parent = ScreenGui
        table.insert(espObjects, label)
    end
end

function ESPSystem:LineESP(player, camera)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local root = player.Character.HumanoidRootPart
    local pos, on = camera:WorldToViewportPoint(root.Position)
    if on then
        local line = Instance.new("Frame")
        line.Size = UDim2.new(0, 1, 0, camera.ViewportSize.Y - pos.Y)
        line.Position = UDim2.new(0, pos.X, 0, pos.Y)
        line.BackgroundColor3 = COLORS.Primary
        line.BorderSizePixel = 0
        line.Parent = ScreenGui
        table.insert(espObjects, line)
    end
end

function ESPSystem:DistanceESP(player, camera)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local root = Utils:GetRoot()
    if not root then return end
    local playerRoot = player.Character.HumanoidRootPart
    local dist = (root.Position - playerRoot.Position).Magnitude
    local pos, on = camera:WorldToViewportPoint(playerRoot.Position + Vector3.new(0, 2, 0))
    if on then
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0, 80, 0, 16)
        label.Position = UDim2.new(0, pos.X - 40, 0, pos.Y + 8)
        label.BackgroundTransparency = 1
        label.Text = math.floor(dist) .. "m"
        label.TextColor3 = COLORS.Warning
        label.TextSize = 10
        label.Font = Enum.Font.Gotham
        label.TextXAlignment = Enum.TextXAlignment.Center
        label.Parent = ScreenGui
        table.insert(espObjects, label)
    end
end

function ESPSystem:Update()
    task.spawn(function()
        while _G.SeraphiCA.IsRunning do
            ESPSystem:ClearESP()
            local camera = Workspace.CurrentCamera
            if not camera then task.wait(0.2) continue end
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    if _G.SeraphiCA.Visuals.ESPBox then ESPSystem:BoxESP(plr, camera) end
                    if _G.SeraphiCA.Visuals.ESPLine then ESPSystem:LineESP(plr, camera) end
                    if _G.SeraphiCA.Visuals.ESPName then ESPSystem:NameESP(plr, camera) end
                    if _G.SeraphiCA.Visuals.ESPDistance then ESPSystem:DistanceESP(plr, camera) end
                end
            end
            task.wait(_G.SeraphiCA.Settings.ESPRefreshRate or 0.15)
        end
    end)
end

