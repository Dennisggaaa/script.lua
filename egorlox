    local tweenTime = math.min((RootPart.Position - position).Magnitude / 300, 3)
    local tween = TweenService:Create(RootPart, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {CFrame = CFrame.new(position)})
