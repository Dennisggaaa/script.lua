local Performance = {}

function Performance:Optimize()
    task.spawn(function()
        while _G.SeraphiCA.IsRunning do
            pcall(function()
                collectgarbage("step", 100)
                if #Workspace:GetChildren() > 5000 then
                    for _, obj in ipairs(Workspace:GetChildren()) do
                        if obj:IsA("Part") and obj.Transparency == 1 and not obj.CanCollide then
                            obj:Destroy()
                        end
                    end
                end
            end)
            task.wait(60)
        end
    end)
end

