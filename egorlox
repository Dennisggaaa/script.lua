local function EncryptKey()
    local key = "081324"
    local encoded = ""
    for i = 1, #key do
        encoded = encoded .. string.char(string.byte(key, i) + 7)
    end
    return encoded
end

local function DecryptKey(encrypted)
    local decoded = ""
    for i = 1, #encrypted do
        decoded = decoded .. string.char(string.byte(encrypted, i) - 7)
    end
    return decoded
end

local ENCRYPTED_KEY = EncryptKey()

