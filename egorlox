local function AnimateLoading()
    local progress = 0
    local steps = 30
    
    for i = 1, steps do
        progress = (i / steps) * 100
        ProgressFill.Size = UDim2.new(progress / 100, 0, 1, 0)
        PercentLabel.Text = math.floor(progress) .. "%"
        
        -- Меняем цвет при 100%
        if progress >= 100 then
            ProgressFill.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
        end
        
        task.wait(0.05 + math.random() * 0.03)
    end
    
    -- Анимация завершения
    TweenService:Create(ProgressFill, TweenInfo.new(0.3), {
        Size = UDim2.new(1, 0, 1, 0)
    }):Play()
    PercentLabel.Text = "100%"
    
    task.wait(0.3)
    
    -- Показываем Welcome
    LoadingFrame.Visible = false
    WelcomeFrame.Visible = true
    WelcomeFrame.BackgroundTransparency = 1
    
    TweenService:Create(WelcomeFrame, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
        BackgroundTransparency = 0
    }):Play()
    
    -- Анимация появления текста
