            fruitText = fruitText .. fruit[1] .. ": " .. string.format("%02d:%02d", minutes, seconds)
            if i < #FruitSpawnTimes then fruitText = fruitText .. "  |  " end
            if i % 3 == 0 and i < #FruitSpawnTimes then fruitText = fruitText .. "\n" end
        end
        FruitList.Text = fruitText
    end
end)

