UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.Insert then
        _G.SeraphiCA.IsMenuOpen = not _G.SeraphiCA.IsMenuOpen
        if mainMenuObj and mainMenuObj.Frame then
            mainMenuObj.Frame.Visible = _G.SeraphiCA.IsMenuOpen
            if _G.SeraphiCA.IsMenuOpen then
                AnimationModule:ScaleIn(mainMenuObj.Frame, 0.3)
            end
        end
    end
    
    if input.KeyCode == Enum.KeyCode.End then
        _G.SeraphiCA.IsRunning = false
        ESPSystem:ClearESP()
        ScreenGui:Destroy()
        script:Destroy()
    end
end)

