function ESPSystem:Update()
    task.spawn(function()
        while _G.SeraphiCA.IsRunning do
            ESPSystem:ClearESP()
            local camera = Workspace.CurrentCamera
            if not camera then task.wait(0.1) continue end
            
            if _G.SeraphiCA.Visuals.ESPBox then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer then ESPSystem:BoxESP(plr, camera) end
                end
            end
            
            if _G.SeraphiCA.Visuals.ESPLine then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer then ESPSystem:LineESP(plr, camera) end
                end
            end
            
            if _G.SeraphiCA.Visuals.ESPName then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer then ESPSystem:NameESP(plr, camera) end
                end
            end
            
            if _G.SeraphiCA.Visuals.ESPDistance then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer then ESPSystem:DistanceESP(plr, camera) end
                end
            end
            
            task.wait(0.1)
        end
    end)
end

