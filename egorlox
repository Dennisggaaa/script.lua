function MainMenu:Show(menuObj)
    menuObj.Frame.Visible = true
    
    -- Scale in from 0
    menuObj.Frame.Size = UDim2.new(0, 0, 0, 0)
    TweenService:Create(menuObj.Frame, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 900, 0, 580)
    }):Play()
    
    -- Fade in background
    menuObj.Frame.BackgroundTransparency = 1
    TweenService:Create(menuObj.Frame, TweenInfo.new(0.4), {
        BackgroundTransparency = 0.04
    }):Play()
end

function MainMenu:Hide(frame)
    TweenService:Create(frame, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1
    }):Play()
    
    task.wait(0.35)
    frame.Visible = false
end

function MainMenu:StartEffects(menuObj)
    -- Glow pulsing
    task.spawn(function()
        while menuObj.OuterGlow and menuObj.OuterGlow.Parent do
            TweenService:Create(menuObj.OuterGlow, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                BackgroundTransparency = 0.86,
                Size = UDim2.new(1, 38, 1, 38),
                Position = UDim2.new(0, -19, 0, -19)
            }):Play()
            TweenService:Create(menuObj.OuterGlow2, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                BackgroundTransparency = 0.92,
                Size = UDim2.new(1, 60, 1, 60),
                Position = UDim2.new(0, -30, 0, -30)
            }):Play()
            task.wait(2)
            TweenService:Create(menuObj.OuterGlow, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                BackgroundTransparency = 0.9,
                Size = UDim2.new(1, 30, 1, 30),
                Position = UDim2.new(0, -15, 0, -15)
            }):Play()
            TweenService:Create(menuObj.OuterGlow2, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                BackgroundTransparency = 0.95,
                Size = UDim2.new(1, 50, 1, 50),
                Position = UDim2.new(0, -25, 0, -25)
            }):Play()
            task.wait(2)
        end
    end)
    
    -- Corner decorations rotation and pulse
    task.spawn(function()
        while menuObj.Corners and #menuObj.Corners > 0 and menuObj.Corners[1].Parent do
            for i, corner in ipairs(menuObj.Corners) do
                corner.Rotation = corner.Rotation + 1.2
                
                TweenService:Create(corner, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                    BackgroundTransparency = 0.5 + math.sin(tick() * 2 + i) * 0.2
                }):Play()
            end
            task.wait(0.03)
        end
    end)
    
    -- Floating particles
    task.spawn(function()
        while menuObj.ParticlesContainer and menuObj.ParticlesContainer.Parent do
            if menuObj.Frame.Visible then
                local x = math.random(0, 900)
                local y = math.random(0, 580)
                ParticleSystem:CreateParticle(menuObj.ParticlesContainer, x, y, math.random(2, 5), {C.Primary, C.Cyan, C.Purple, C.Pink}[math.random(1, 4)], 15, 4)
            end
            task.wait(0.15)
        end
    end)
    
    -- Title text glow
    task.spawn(function()
        while menuObj.TitleText and menuObj.TitleText.Parent do
            TweenService:Create(menuObj.TitleText, TweenInfo.new(2.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                TextStrokeTransparency = 0.15
            }):Play()
            task.wait(2.5)
            TweenService:Create(menuObj.TitleText, TweenInfo.new(2.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                TextStrokeTransparency = 0.35
            }):Play()
            task.wait(2.5)
        end
    end)
    
    -- Close button glow
    task.spawn(function()
        while menuObj.CloseGlow and menuObj.CloseGlow.Parent do
            TweenService:Create(menuObj.CloseGlow, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                BackgroundTransparency = 0.78,
                Size = UDim2.new(1, 14, 1, 14),
                Position = UDim2.new(0, -7, 0, -7)
            }):Play()
            task.wait(1.2)
            TweenService:Create(menuObj.CloseGlow, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                BackgroundTransparency = 0.85,
                Size = UDim2.new(1, 8, 1, 8),
                Position = UDim2.new(0, -4, 0, -4)
            }):Play()
            task.wait(1.2)
        end
    end)
    
    -- Glass overlay shimmer
    task.spawn(function()
        while menuObj.GlassTop and menuObj.GlassTop.Parent do
            TweenService:Create(menuObj.GlassTop, TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                BackgroundTransparency = 0.92
            }):Play()
            task.wait(3)
            TweenService:Create(menuObj.GlassTop, TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                BackgroundTransparency = 0.96
            }):Play()
            task.wait(3)
        end
    end)
end

