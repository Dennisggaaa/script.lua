    local progress = 0
    while progress < 100 do
        progress = progress + math.random(1, 3)
        if progress > 100 then progress = 100 end
        progressFill.Size = UDim2.new(progress / 100, 0, 1, 0)
        percentLabel.Text = math.floor(progress) .. "%"
        wait(0.04 + math.random() * 0.02)
    end
    progressFill.BackgroundColor3 = C.Success
    percentLabel.TextColor3 = C.Success
    percentLabel.Text = "100%"
    wait(0.5)
    if callback then callback() end
end

