local ParticleSystem = {}

function ParticleSystem:CreateParticle(parent, x, y, size, color, speed, lifespan)
    local particle = Instance.new("Frame")
    particle.Size = UDim2.new(0, size or 4, 0, size or 4)
    particle.Position = UDim2.new(0, x, 0, y)
    particle.BackgroundColor3 = color or C.Primary
    particle.BorderSizePixel = 0
    particle.BackgroundTransparency = 0.5
    particle.ZIndex = 150
    particle.Parent = parent
    
    Instance.new("UICorner", particle).CornerRadius = UDim.new(0, size/2 or 2)
    
    task.spawn(function()
        local startTime = tick()
        local life = lifespan or (3 + math.random() * 4)
        local speedX = (math.random() - 0.5) * (speed or 20)
        local speedY = (math.random() - 0.5) * (speed or 20) - 10
        local startX = x
        local startY = y
        
        while tick() - startTime < life and particle.Parent do
            local elapsed = tick() - startTime
            local progress = elapsed / life
            local newX = startX + speedX * elapsed
            local newY = startY + speedY * elapsed + 50 * progress * progress
            
            particle.Position = UDim2.new(0, newX, 0, newY)
            particle.BackgroundTransparency = 0.5 + progress * 0.5
            particle.Size = UDim2.new(0, size * (1 - progress * 0.7), 0, size * (1 - progress * 0.7))
            
            task.wait(0.03)
        end
        
        pcall(function() particle:Destroy() end)
    end)
    
    return particle
end

function ParticleSystem:Burst(parent, count, x, y, colors, sizeRange, speed, lifespan)
    for i = 1, count do
        local size = math.random(sizeRange[1] or 2, sizeRange[2] or 6)
        local color = colors[math.random(1, #colors)]
        local angle = math.random() * math.pi * 2
        local dist = math.random(10, 60)
        local px = x + math.cos(angle) * dist
        local py = y + math.sin(angle) * dist
        ParticleSystem:CreateParticle(parent, px, py, size, color, speed, lifespan)
    end
end

function ParticleSystem:Trail(parent, x, y, count, color, size)
    for i = 1, count do
        ParticleSystem:CreateParticle(parent, x + math.random(-5, 5), y + math.random(-5, 5), size or 3, color, 5, 1.5)
    end
end

