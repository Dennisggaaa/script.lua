local function ScanGamePasses()
    local found = {}
    local containers = {ReplicatedStorage, Workspace, ServerScriptService}
    for _, container in ipairs(containers) do
        if container then
            for _, child in ipairs(container:GetDescendants()) do
                local name = child.Name
                if name and (string.find(string.lower(name), "pass") or string.find(string.lower(name), "gamepass") or string.find(string.lower(name), "game pass")) then
                    local id = nil
                    if child:IsA("IntValue") or child:IsA("NumberValue") then
                        id = child.Value
                    elseif child:IsA("StringValue") then
                        id = tonumber(child.Value)
                    elseif child:IsA("ObjectValue") and child.Value and child.Value:IsA("IntValue") then
                        id = child.Value.Value
                    elseif child:IsA("Folder") then
                        for _, sub in ipairs(child:GetChildren()) do
                            if sub:IsA("IntValue") and sub.Name:find("ID") then
                                id = sub.Value
                                break
                            end
                        end
                    end
                    if id and type(id) == "number" and id > 0 then
                        local nameDisplay = child.Name
                        if child:IsA("IntValue") and child.Parent then
                            nameDisplay = child.Parent.Name .. " (" .. child.Name .. ")"
                        end
                        table.insert(found, {id = id, name = nameDisplay})
                    end
                end
            end
        end
    end
    local unique = {}
    local seen = {}
    for _, item in ipairs(found) do
        if not seen[item.id] then
            seen[item.id] = true
            table.insert(unique, item)
        end
    end
    return unique
end

