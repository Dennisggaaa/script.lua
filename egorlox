function Utils:GetNearestPlayer(range)
    range = range or 50
    local nearest = nil
    local minDist = range
    local root = Utils:GetRoot()
    if not root then return nil end
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local plrRoot = plr.Character:FindFirstChild("HumanoidRootPart")
            if plrRoot then
                local dist = (root.Position - plrRoot.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = plr
                end
            end
        end
    end
    return nearest
end

function Utils:GetNearestNPC(range)
    range = range or 100
    local nearest = nil
    local minDist = range
    local root = Utils:GetRoot()
    if not root then return nil end
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            if not Players:GetPlayerFromCharacter(obj) then
                local dist = (root.Position - obj.HumanoidRootPart.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = obj
                end
            end
        end
    end
    return nearest
end

function Utils:GetAllNPCs(range)
    range = range or 200
    local npcs = {}
    local root = Utils:GetRoot()
    if not root then return npcs end
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            if not Players:GetPlayerFromCharacter(obj) then
                local dist = (root.Position - obj.HumanoidRootPart.Position).Magnitude
                if dist < range then
                    table.insert(npcs, obj)
                end
            end
        end
    end
    return npcs
end

