        TextTransparency = 0
    }):Play()
    
    task.wait(0.3)
    
    SubText.TextTransparency = 1
    TweenService:Create(SubText, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
        TextTransparency = 0
    }):Play()
    
