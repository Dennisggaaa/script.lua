        opened = false
        listFrame.Visible = false
        listFrame.Size = UDim2.new(1, 0, 0, 0)
        btn.Text = btn.Text:gsub("▲", "▼")
    end
    
    local function OpenList()
        opened = true
        listFrame.Visible = true
        listFrame.Size = UDim2.new(1, 0, 0, #options * 34)
        btn.Text = btn.Text:gsub("▼", "▲")
    end
    
