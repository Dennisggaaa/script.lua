-- ===================== DRAG =====================
local function SetupDrag()
    local dragStart = nil
    local frameStart = nil

    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragStart = input.Position
            frameStart = MenuFrame.Position
            SeraphMenu.Dragging = true
            TweenService:Create(MenuFrame, TweenInfo.new(0.15), {BackgroundTransparency = 0.05}):Play()
        end
    end)

    TitleBar.InputChanged:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) and SeraphMenu.Dragging then
            local delta = input.Position - dragStart
            MenuFrame.Position = UDim2.new(
                frameStart.X.Scale,
                frameStart.X.Offset + delta.X,
                frameStart.Y.Scale,
                frameStart.Y.Offset + delta.Y
            )
        end
    end)

    TitleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            SeraphMenu.Dragging = false
            TweenService:Create(MenuFrame, TweenInfo.new(0.15), {BackgroundTransparency = 0.1}):Play()
        end
    end)
end
SetupDrag()

-- ===================== BUBBLE ANIMATION =====================
local function CreateBubble()
    local bubble = Instance.new("Frame")
    bubble.Size = UDim2.new(0, 0, 0, 0)
    bubble.Position = UDim2.new(0, 0, 0, 0)
    bubble.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    bubble.BackgroundTransparency = 0.8
    bubble.BorderSizePixel = 0
    bubble.ZIndex = 0
    bubble.Parent = WatermarkContainer
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = bubble
    return bubble
end

local bubble = CreateBubble()
local isBubbleAnimating = false

local function BubbleOut()
    if isBubbleAnimating then return end
    isBubbleAnimating = true
    bubble.Visible = true
    bubble.Size = UDim2.new(0, 10, 0, 10)
    bubble.Position = UDim2.new(0, WatermarkContainer.AbsoluteSize.X/2 - 5, 0, WatermarkContainer.AbsoluteSize.Y/2 - 5)
    bubble.BackgroundTransparency = 0.8
    
    local tween1 = TweenService:Create(bubble, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 60, 0, 60),
        BackgroundTransparency = 0.3
    })
    tween1:Play()
    tween1.Completed:Connect(function()
        local tween2 = TweenService:Create(bubble, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            BackgroundTransparency = 1
        })
        tween2:Play()
        tween2.Completed:Connect(function()
            bubble.Visible = false
            isBubbleAnimating = false
        end)
    end)
end

local function BubbleIn()
    if isBubbleAnimating then return end
    isBubbleAnimating = true
    bubble.Visible = true
    bubble.Size = UDim2.new(0, 60, 0, 60)
    bubble.Position = UDim2.new(0, WatermarkContainer.AbsoluteSize.X/2 - 30, 0, WatermarkContainer.AbsoluteSize.Y/2 - 30)
    bubble.BackgroundTransparency = 0.3
    
    local tween1 = TweenService:Create(bubble, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 10, 0, 10),
        BackgroundTransparency = 0.8
    })
    tween1:Play()
    tween1.Completed:Connect(function()
        bubble.Visible = false
        isBubbleAnimating = false
    end)
end

