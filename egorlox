    local function SpawnParticles(from, to, count)
        count = count or (_G.ParticleCount or 50)
        for i = 1, count do
            local p = Instance.new("Frame")
            p.Size = UDim2.new(0, math.random(3, 8), 0, math.random(3, 8))
            p.Position = UDim2.new(0, from.X + math.random(-15, 15), 0, from.Y + math.random(-15, 15))
            p.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
            p.BackgroundTransparency = 0.8
            p.BorderSizePixel = 0
            p.Parent = ScreenGui
            
            local cor = Instance.new("UICorner")
            cor.CornerRadius = UDim.new(0, 10)
            cor.Parent = p
            
            local tween = TweenService:Create(p, TweenInfo.new(math.random(3, 6), Enum.EasingStyle.Quad), {
                Position = UDim2.new(0, to.X + math.random(-60, 60), 0, to.Y + math.random(-60, 60)),
                BackgroundTransparency = 1,
                Size = UDim2.new(0, math.random(10, 30), 0, math.random(10, 30))
            })
            tween:Play()
            tween.Completed:Connect(function() p:Destroy() end)
            table.insert(particles, p)
        end
    end

    local function ToggleMenu()
        menuOpen = not menuOpen
        local wmPos = WatermarkHolder.AbsolutePosition
        local wmSize = WatermarkHolder.AbsoluteSize
        local cx = wmPos.X + wmSize.X / 2
        local cy = wmPos.Y + wmSize.Y / 2
        
        if menuOpen then
            MainFrame.Visible = true
            MainFrame.Position = UDim2.new(0, cx - 20, 0, cy - 20)
            MainFrame.Size = UDim2.new(0, 40, 0, 40)
            MainFrame.BackgroundTransparency = 0.2
            
            SpawnParticles(Vector2.new(cx, cy), Vector2.new(MainFrame.AbsolutePosition.X + MenuSize/2, MainFrame.AbsolutePosition.Y + MenuSize*0.335))
            
            local half = MenuSize / 2
            TweenService:Create(MainFrame, TweenInfo.new(0.8, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Position = UDim2.new(0.5, -half, 0.5, -MenuSize * 0.335),
                Size = UDim2.new(0, MenuSize, 0, MenuSize * 0.67),
                BackgroundTransparency = 0
            }):Play()
            
            TweenService:Create(MainGlow, TweenInfo.new(1, Enum.EasingStyle.Sine), {
                BackgroundTransparency = 0.85,
                Size = UDim2.new(1, 70, 1, 70),
                Position = UDim2.new(0, -35, 0, -35)
            }):Play()
            
            task.wait(0.4)
            ContentContainer.Visible = true
            TabContainer.Visible = true
            TitleBar.Visible = true
        else
            ContentContainer.Visible = false
            TabContainer.Visible = false
            TitleBar.Visible = false
            
            local curPos = MainFrame.AbsolutePosition
            local curSize = MainFrame.AbsoluteSize
            
            TweenService:Create(MainFrame, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                Position = UDim2.new(0, cx - 20, 0, cy - 20),
                Size = UDim2.new(0, 40, 0, 40),
                BackgroundTransparency = 0.8
            }):Play()
            
            SpawnParticles(Vector2.new(curPos.X + curSize.X/2, curPos.Y + curSize.Y/2), Vector2.new(cx, cy))
            
            task.wait(0.6)
            MainFrame.Visible = false
        end
    end

