                    for _, k in ipairs(keys) do
                        pcall(function()
                            VirtualInputManager:SendKeyEvent(true, k, false, nil)
                            task.wait(0.04)
                            VirtualInputManager:SendKeyEvent(false, k, false, nil)
                            task.wait(0.2)
                        end)
                    end
                    task.wait(0.5)
                end
            end)
        end
    end)

