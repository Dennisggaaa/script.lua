local function CreateExplosionParticles(position, count, color)
    local container = Instance.new("Folder")
    container.Name = "ExplosionParticles"
    container.Parent = ScreenGui
    
    for i = 1, count do
        local p = Instance.new("Frame")
        p.Size = UDim2.new(0, math.random(3, 8), 0, math.random(3, 8))
        p.Position = position
        p.BackgroundColor3 = color or Color3.fromRGB(255, 215, 0)
        p.BackgroundTransparency = 0.3 + math.random() * 0.4
        p.BorderSizePixel = 0
        p.ZIndex = 10
        p.Parent = container
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(1, 0)
        corner.Parent = p
        
        local angle = math.random() * 2 * math.pi
        local dist = math.random(50, 200)
        local targetPos = UDim2.new(
            position.X.Scale + math.cos(angle) * dist / ScreenGui.AbsoluteSize.X,
            position.X.Offset + math.cos(angle) * dist,
            position.Y.Scale + math.sin(angle) * dist / ScreenGui.AbsoluteSize.Y,
            position.Y.Offset + math.sin(angle) * dist
        )
        local duration = 0.5 + math.random() * 0.5
        
        TweenService:Create(p, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = targetPos,
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 0, 0, 0)
        }):Play()
        
        task.spawn(function()
            task.wait(duration + 0.1)
            p:Destroy()
        end)
    end
    
    task.spawn(function()
        task.wait(1.5)
        container:Destroy()
    end)
end

