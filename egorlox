function ExecuteFarmFunction(key, active)
    if key == "AutoFarm" then
        task.spawn(function()
            while Settings.AutoFarm do
                task.wait(0.5)
                local events = ReplicatedStorage:FindFirstChild("Events")
                if events then
                    local farmEvent = events:FindFirstChild("CollectMoney")
                    if farmEvent then farmEvent:FireServer() end
                end
                local cash = LocalPlayer:FindFirstChild("leaderstats")
                if cash and cash:FindFirstChild("Cash") then
                    cash.Cash.Value = cash.Cash.Value + 100
                end
            end
        end)
    elseif key == "AutoBuild" then
        task.spawn(function()
            while Settings.AutoBuild do
                task.wait(1)
                local events = ReplicatedStorage:FindFirstChild("Events")
                if events then
                    local buildEvent = events:FindFirstChild("BuildStructure")
                    if buildEvent then buildEvent:FireServer() end
                end
            end
        end)
    elseif key == "AutoUpgrade" then
        task.spawn(function()
            while Settings.AutoUpgrade do
                task.wait(2)
                local events = ReplicatedStorage:FindFirstChild("Events")
                if events then
                    local upgradeEvent = events:FindFirstChild("UpgradeBase")
                    if upgradeEvent then upgradeEvent:FireServer() end
                end
            end
        end)
    elseif key == "AutoAttack" then
        task.spawn(function()
            while Settings.AutoAttack do
                task.wait(0.3)
                local events = ReplicatedStorage:FindFirstChild("Events")
                if events then
                    local attackEvent = events:FindFirstChild("AttackEnemy")
                    if attackEvent then attackEvent:FireServer() end
                end
            end
        end)
    elseif key == "SpeedBypass" then
        task.spawn(function()
            while Settings.SpeedBypass do
                task.wait(0.1)
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.WalkSpeed = Settings.SpeedValue or 50
                end
            end
        end)
    elseif key == "AntiAFK" then
        task.spawn(function()
            while Settings.AntiAFK do
                task.wait(60)
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame + Vector3.new(0, 0.1, 0)
                end
            end
        end)
    elseif key == "ESP" then
        task.spawn(function()
            while Settings.ESP do
                task.wait(0.1)
                for _, v in pairs(Workspace:GetChildren()) do
                    if v:IsA("Model") and v:FindFirstChild("Humanoid") and v ~= LocalPlayer.Character then
