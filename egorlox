                btn.BackgroundColor3 = Color3.fromRGB(30, 30, 60)
            end
            tabBtn.BackgroundColor3 = COLORS.Primary
            AnimationModule:Flash(tabBtn, COLORS.White, 0.12)
            if mainMenuObj then
                local builder = tabBuilders[tabNames[i]]
                if builder then builder(mainMenuObj.Content) end
            end
        end)
        
        table.insert(tabButtons, tabBtn)
    end
    
    -- Content frame
    local contentFrame = Instance.new("Frame")
    contentFrame.Size = UDim2.new(1, -20, 1, -90)
    contentFrame.Position = UDim2.new(0, 10, 0, 86)
    contentFrame.BackgroundTransparency = 1
    contentFrame.Parent = frame
    
    return {Frame = frame, Content = contentFrame, TitleBar = titleBar}
end

