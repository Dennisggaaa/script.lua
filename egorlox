local AnimationModule = {}

function AnimationModule:FadeIn(object, duration)
    duration = duration or 0.5
    object.BackgroundTransparency = 1
    object.Visible = true
    TweenService:Create(object, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
        BackgroundTransparency = 0
    }):Play()
end

function AnimationModule:FadeOut(object, duration, callback)
    duration = duration or 0.5
    TweenService:Create(object, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.In), {
        BackgroundTransparency = 1
    }):Play()
    task.wait(duration)
    object.Visible = false
    if callback then callback() end
end

function AnimationModule:SlideIn(object, direction, duration)
    duration = duration or 0.5
    local origPos = UDim2.new(object.Position.X.Scale, object.Position.X.Offset, object.Position.Y.Scale, object.Position.Y.Offset)
    local startPos = UDim2.new(origPos.X.Scale, origPos.X.Offset, origPos.Y.Scale, origPos.Y.Offset)
    
    if direction == "left" then startPos = UDim2.new(startPos.X.Scale, startPos.X.Offset - 100, startPos.Y.Scale, startPos.Y.Offset)
    elseif direction == "right" then startPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + 100, startPos.Y.Scale, startPos.Y.Offset)
    elseif direction == "up" then startPos = UDim2.new(startPos.X.Scale, startPos.X.Offset, startPos.Y.Scale, startPos.Y.Offset - 100)
    elseif direction == "down" then startPos = UDim2.new(startPos.X.Scale, startPos.X.Offset, startPos.Y.Scale, startPos.Y.Offset + 100) end
    
    object.Position = startPos
    object.Visible = true
    TweenService:Create(object, TweenInfo.new(duration, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = origPos
    }):Play()
end

function AnimationModule:ScaleIn(object, duration)
    duration = duration or 0.5
    local startSize = object.Size
    object.Size = UDim2.new(0, 0, 0, 0)
    object.Visible = true
    TweenService:Create(object, TweenInfo.new(duration, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = startSize
    }):Play()
end

function AnimationModule:ScaleOut(object, duration, callback)
    duration = duration or 0.5
    TweenService:Create(object, TweenInfo.new(duration, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0)
    }):Play()
    task.wait(duration)
    object.Visible = false
    if callback then callback() end
end

function AnimationModule:Pulse(object, duration, scale)
    scale = scale or 1.1
    duration = duration or 1
    TweenService:Create(object, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
        Size = UDim2.new(0, object.Size.X.Offset * scale, 0, object.Size.Y.Offset * scale)
    }):Play()
    task.wait(duration)
    TweenService:Create(object, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
        Size = UDim2.new(0, object.Size.X.Offset / scale, 0, object.Size.Y.Offset / scale)
    }):Play()
end

function AnimationModule:Shake(object, intensity, duration)
    intensity = intensity or 5
    duration = duration or 0.5
    local startPos = object.Position
    for i = 1, 10 do
        object.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + math.random(-intensity, intensity), startPos.Y.Scale, startPos.Y.Offset + math.random(-intensity, intensity))
        task.wait(duration / 10)
    end
    object.Position = startPos
end

function AnimationModule:GlowPulse(glow, intensity)
    task.spawn(function()
        while glow and glow.Parent do
            TweenService:Create(glow, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                BackgroundTransparency = 0.7,
                Size = UDim2.new(1, intensity or 15, 1, intensity or 15)
            }):Play()
            task.wait(1.5)
            TweenService:Create(glow, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                BackgroundTransparency = 0.9,
                Size = UDim2.new(1, 8, 1, 8)
            }):Play()
            task.wait(1.5)
        end
    end)
end

function AnimationModule:Typewriter(label, text, speed)
    speed = speed or 0.05
    label.Text = ""
    for i = 1, #text do
        label.Text = string.sub(text, 1, i)
