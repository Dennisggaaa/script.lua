local ProtectionSystem = {}

function ProtectionSystem:Init()
    task.spawn(function()
        while _G.SeraphiCA.IsRunning do
            pcall(function()
                if script then
                    script.Name = "Sys_" .. math.random(100000, 999999)
                end
                
                for _, remote in ipairs(ReplicatedStorage:GetChildren()) do
                    if remote:IsA("RemoteEvent") and remote.Name:find("Detect") then
                        remote:Destroy()
                    end
                end
                
                for _, obj in ipairs(Workspace:GetChildren()) do
                    if obj:IsA("Model") and obj.Name:find("Admin") then
                        obj:Destroy()
                    end
                end
                
                local globals = {"SeraphiCA", "ESPBox", "AimFOV", "AutoParry"}
                for _, g in ipairs(globals) do
                    if rawget(_G, g .. "_Backup") then
                        rawset(_G, g, rawget(_G, g .. "_Backup"))
                    end
                end
            end)
            task.wait(30)
        end
    end)
end

